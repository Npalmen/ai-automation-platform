# Python
__pycache__/
*.py[cod]
*$py.class

# Env
.env
.env.*
.env.browser-test
scripts/.env.browser-test
.venv/
venv/

# Browser matrix temp artifacts (may contain failure screenshots)
scripts/.browser-matrix-tmp/

# OS / Editor
.DS_Store
Thumbs.db
.vscode/

# VSCode
.vscode/

# Local dev runtime logs (do not commit)
storage/local_dev/logs/

# Live eval run journals/reports (2F testbot; never commit)
storage/live_eval/
storage/local_dev/live_eval/
**/live_eval/runs/**/transitions.jsonl
**/live_eval/runs/**/report.json
**/live_eval/runs/**/run_config.json

# Local live-eval OAuth/testbot credential files (never commit)
scripts/.live_eval*
storage/**/.live_eval*

# Dev HTTPS proxy certs (local only)
scripts/.dev-certs/

# One-time Visma OAuth migration payloads (never commit)
scripts/ops/.tmp/

# Cursor IDE
.cursor/

# Frontend build artifacts
frontend/dist/
frontend/node_modules/

# Generated verification reports (may contain environment-specific metadata)
scripts/*_report.json
scripts/kapitel*_report.json

# Local deploy bundles (git archive output)
k12-rc-bundle.tar.gz
