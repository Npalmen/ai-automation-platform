# Browser matrix credentials — NOT in git.
# Copy to /opt/krowolf/.env.browser-test on pilot server.
# chmod 600 /opt/krowolf/.env.browser-test
# chown root:root /opt/krowolf/.env.browser-test

K12_BROWSER_BASE_URL=https://api.krowolf.se
K12_BROWSER_USERNAME=
K12_BROWSER_PASSWORD=
K12_BROWSER_ROLE=
K12_BROWSER_HEADLESS=true
K12_BROWSER_REPORT_PATH=/opt/krowolf/storage/status/k12_browser_pilot_report.json

# Optional — isolated test tenant for approval-first (no production customer data)
# K12_BROWSER_TEST_TENANT=T_K12_BROWSER
# K12_BROWSER_SETUP_APPROVAL=true
# K12_BROWSER_CHROME_PATH=/usr/bin/chromium
