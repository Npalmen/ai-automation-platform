# Offsite backup credentials — NOT in git. Copy to /opt/krowolf/.env.offsite on server.
# chmod 600 /opt/krowolf/.env.offsite

# Option A: S3-compatible object storage (Hetzner Object Storage, AWS S3, B2, etc.)
OFFSITE_S3_ENDPOINT=https://hel1.your-objectstorage.com
OFFSITE_S3_BUCKET=your-bucket-name
OFFSITE_S3_ACCESS_KEY_ID=
OFFSITE_S3_SECRET_ACCESS_KEY=
OFFSITE_S3_PREFIX=krowolf-backups
OFFSITE_S3_REGION=us-east-1

# Option B: separate physical mount (NOT same disk as BACKUP_DIR)
# OFFSITE_BACKUP_DEST_DIR=/mnt/offsite/krowolf-backups

OFFSITE_STATUS_FILE=/opt/krowolf/storage/status/offsite_status.json
