# Copy this file to .env and fill in the required values.
# Usage: cp env.example .env

# ── Auth / API keys ──────────────────────────────────────────
# JSON object mapping tenant_id to API key.
# If empty or unset, auth is DISABLED and X-Tenant-ID header is trusted (dev mode).
# Example: TENANT_API_KEYS='{"TENANT_1001": "key-abc123", "TENANT_2001": "key-def456"}'
TENANT_API_KEYS=

# ── Application ──────────────────────────────────────────────
APP_NAME=AI Automation Platform
ENV=dev
HOST=127.0.0.1
PORT=8000
STORAGE_PATH=./storage/local_dev

# ── Database ─────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_platform

# ── LLM (OpenAI) ─────────────────────────────────────────────
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=                        # Required for AI processing
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1200
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_DELAY_SECONDS=0.8

# ── Google Mail (Gmail) ───────────────────────────────────────
# Required only if using the Gmail send_email integration.
GOOGLE_MAIL_API_URL=https://gmail.googleapis.com/gmail/v1
GOOGLE_MAIL_ACCESS_TOKEN=           # OAuth2 access token
GOOGLE_MAIL_USER_ID=me

# ── Other integrations (leave blank if unused) ────────────────
CRM_WEBHOOK_URL=
CRM_API_KEY=

ACCOUNTING_WEBHOOK_URL=
ACCOUNTING_API_KEY=

SUPPORT_WEBHOOK_URL=
SUPPORT_API_KEY=

SLACK_WEBHOOK_URL=

MONDAY_API_URL=https://api.monday.com/v2
MONDAY_API_KEY=
MONDAY_BOARD_ID=0

FORTNOX_API_URL=https://api.fortnox.se/3
FORTNOX_ACCESS_TOKEN=
FORTNOX_CLIENT_SECRET=

VISMA_API_URL=https://eaccountingapi.vismaonline.com/v2
VISMA_ACCESS_TOKEN=

GOOGLE_CALENDAR_API_URL=https://www.googleapis.com/calendar/v3
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

MICROSOFT_GRAPH_API_URL=https://graph.microsoft.com/v1.0
MICROSOFT_MAIL_ACCESS_TOKEN=
MICROSOFT_CALENDAR_ACCESS_TOKEN=
MICROSOFT_CALENDAR_TIMEZONE=W. Europe Standard Time
