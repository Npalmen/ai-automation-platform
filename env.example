# Copy this file to .env and fill in the required values.
# Usage: cp env.example .env

# ── Auth / API keys ──────────────────────────────────────────
# JSON object mapping tenant_id to API key.
# If empty or unset, auth is DISABLED and X-Tenant-ID header is trusted (dev mode).
# Example: TENANT_API_KEYS='{"TENANT_1001": "key-abc123", "TENANT_2001": "key-def456"}'
TENANT_API_KEYS=

# Super-admin API key — required for GET /admin/tenants/overview and future admin endpoints.
# Use X-Admin-API-Key header. Tenant X-API-Key keys are NOT accepted.
# If unset, admin endpoints return 401 (fail closed). Keep this value secret.
ADMIN_API_KEY=

# Optional: comma-separated list of admin API keys.
# When set and non-empty, ADMIN_API_KEYS takes precedence over ADMIN_API_KEY.
# Useful for key rotation (add new key, roll out, remove old key).
# Example: ADMIN_API_KEYS=key1,key2,key3
ADMIN_API_KEYS=

# ── Admin session auth (username + password login) ────────────
# Username for admin UI login (default: admin)
ADMIN_USERNAME=admin

# PBKDF2-HMAC-SHA256 hash of admin password.
# Generate with:
#   python -c "from app.core.admin_session import hash_password; print(hash_password('yourpassword'))"
ADMIN_PASSWORD_HASH=

# Secret key for signing session cookies (random 32-byte base64 string).
# Generate with:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SESSION_SECRET_KEY=

# ── Application ──────────────────────────────────────────────
APP_NAME=AI Automation Platform
ENV=dev
HOST=127.0.0.1
PORT=8000
STORAGE_PATH=./storage/local_dev

# ── Monitoring (scripts/check_production_health.sh) ──────────
# Base URL of the application — used for GET / health check.
# Production: https://api.krowolf.se  Local dev: http://localhost:8000
APP_BASE_URL=http://localhost:8000
# Full URL for /health endpoint. Defaults to APP_BASE_URL/health if unset.
APP_HEALTH_URL=
# curl timeout per HTTP request in seconds (default: 10)
HTTP_TIMEOUT=10
# Name of the running app Docker container (default: leave empty for local dev)
DOCKER_APP_CONTAINER=
# Maximum disk usage % before alerting (default: 80)
DISK_USAGE_MAX_PERCENT=80
# Filesystem path to check for disk usage (default: /)
DISK_CHECK_PATH=/
# Path to docker-compose.prod.yml — if set, appends compose ps to health report.
COMPOSE_FILE=
# Alert hook: shell command run (with report on stdin) when any health check fails.
# Example (email): ALERT_COMMAND=mail -s "Krowolf alert" ops@krowolf.se
# Example (slack): ALERT_COMMAND=curl -sS -X POST ${SLACK_WEBHOOK_URL} -d @-
# Leave empty to disable automatic alerting (check still exits non-zero on failure).
ALERT_COMMAND=

# ── Database ─────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_platform
POSTGRES_DB=ai_platform
POSTGRES_PASSWORD=postgres

# ── Backup (scripts/backup_postgres.sh) ──────────────────────
# Name of the running Postgres Docker container.
# Production: krowolf-db-1. Leave empty to use pg_dump directly.
DOCKER_DB_CONTAINER=
# Directory where local backup files are stored.
BACKUP_DIR=/opt/krowolf/backups
# Delete local backups older than this many days (0 = keep forever).
BACKUP_RETENTION_DAYS=30

# Status metadata (Kapitel 8) — same env var names in scripts and backend.
# Local dev (repo root): ./storage/status/…
# Host cron/production scripts: /opt/krowolf/storage/status/…
# App container (bind mount ./storage:/app/storage): /app/storage/status/…
BACKUP_STATUS_FILE=./storage/status/backup_status.json
RESTORE_STATUS_FILE=./storage/status/restore_status.json
STORAGE_DIR=./storage

# Freshness thresholds for system status API (hours/days).
BACKUP_EXPECTED_INTERVAL_HOURS=24
BACKUP_MAX_AGE_HOURS=25
RESTORE_TEST_MAX_AGE_DAYS=30

# Optional: shell command run after each successful local backup.
# Receives the backup file path as $1. Used for offsite upload.
# Example (rclone): rclone copy $1 remote:krowolf-backups/
# Example (aws s3): aws s3 cp $1 s3://your-bucket/krowolf-backups/
OFFSITE_BACKUP_COMMAND=

# ── Backup freshness check (scripts/check_backup_freshness.sh) ──
# Alert if newest backup is older than this many hours (default: 25).
BACKUP_MAX_AGE_HOURS=25
# Alert if newest backup file is smaller than this many bytes (default: 1024).
BACKUP_MIN_SIZE_BYTES=1024

# ── LLM (OpenAI) ─────────────────────────────────────────────
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=                        # Required for AI processing
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1200
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_DELAY_SECONDS=0.8

# ── Google Mail (Gmail) ───────────────────────────────────────
# Required only if using the Gmail send_email integration.
GOOGLE_MAIL_API_URL=https://gmail.googleapis.com/gmail/v1
GOOGLE_MAIL_ACCESS_TOKEN=           # OAuth2 access token (short-lived, ~1 hour)
GOOGLE_MAIL_USER_ID=me

# OAuth token refresh — set all three to enable automatic refresh on 401.
# Obtain via Google OAuth2 consent flow with gmail.send scope.
GOOGLE_OAUTH_REFRESH_TOKEN=         # Long-lived refresh token
GOOGLE_OAUTH_CLIENT_ID=             # OAuth2 client ID from Google Cloud Console
GOOGLE_OAUTH_CLIENT_SECRET=         # OAuth2 client secret from Google Cloud Console

# ── Other integrations (leave blank if unused) ────────────────
CRM_WEBHOOK_URL=
CRM_API_KEY=

ACCOUNTING_WEBHOOK_URL=
ACCOUNTING_API_KEY=

SUPPORT_WEBHOOK_URL=
SUPPORT_API_KEY=

SLACK_WEBHOOK_URL=

MONDAY_API_URL=https://api.monday.com/v2
MONDAY_API_KEY=
MONDAY_BOARD_ID=0

FORTNOX_API_URL=https://api.fortnox.se/3
FORTNOX_ACCESS_TOKEN=
FORTNOX_CLIENT_SECRET=

VISMA_API_URL=https://eaccountingapi.vismaonline.com/v2
VISMA_ACCESS_TOKEN=
VISMA_CLIENT_ID=
VISMA_CLIENT_SECRET=
VISMA_REDIRECT_URI=
VISMA_SCOPES=ea:api, ea:sales, ea:purchase, ea:accounting, vls:api, offline_access

GOOGLE_CALENDAR_API_URL=https://www.googleapis.com/calendar/v3
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

MICROSOFT_GRAPH_API_URL=https://graph.microsoft.com/v1.0
MICROSOFT_MAIL_ACCESS_TOKEN=
MICROSOFT_CALENDAR_ACCESS_TOKEN=
MICROSOFT_CALENDAR_TIMEZONE=W. Europe Standard Time
